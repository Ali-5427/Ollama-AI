{
  "rewrites": [
    {
      "source": "/_vercel/insights/:path*",
      "destination": "/_vercel/insights/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "/frontend/static/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/index.html"
    }
  ]
}
